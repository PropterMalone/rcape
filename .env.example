# CourtListener — free token at https://www.courtlistener.com/profile/
# Single token (125 requests/day ≈ 7 cases/day):
COURTLISTENER_API_TOKEN=
# OR a comma-separated POOL of tokens to raise the ceiling — each token is a
# separate CL account with its own 125/day budget, so N tokens ≈ 7N cases/day.
# If set, this takes precedence over COURTLISTENER_API_TOKEN.
# COURTLISTENER_API_TOKENS=token-a,token-b,token-c

# Default docket for the operator build path (Abrego Garcia v. Noem, D. Md.)
RCAPE_DOCKET_ID=69777799
# How many leading entries to hash documents for (build path)
RCAPE_HASH_FIRST_N=15
# How many recent entries stage:posts proposes (stage path)
RCAPE_BACKFILL_N=10

# Self-hosted PDS on Malone. Admin password also lives in pds/pds.env; copy it
# here so the provisioner can mint case accounts.
PDS_HOSTNAME=pds.rcape.org
PDS_ADMIN_PASSWORD=

# Handle domain the PDS issues handles under (matches PDS_SERVICE_HANDLE_DOMAINS)
RCAPE_HANDLE_DOMAIN=rcape.org
# The main R.C. Ape "Librarian" bot identity — the account that receives
# @-mentions. Mint it, then fill its DID + password here to run `npm run bot`.
RCAPE_BOT_HANDLE=ape.rcape.org
RCAPE_BOT_DID=
RCAPE_BOT_PASSWORD=
# Owner whose follows ∪ followers form the bot's allowlist (handle or DID)
RCAPE_OWNER_HANDLE=proptermalone.bsky.social
# Allowlist cache TTL (ms). Soft cache only — drain re-checks membership before
# provisioning, so this just bounds how stale an enqueue-time decision can be.
RCAPE_ALLOWLIST_TTL_MS=60000
# Bot notification poll interval (ms)
RCAPE_POLL_INTERVAL_MS=60000

# Watched-case monitor: how long a shelved case rests before it's re-checked for
# new filings (ms; default 3 days), and the max cases checked per poll cycle.
RCAPE_MONITOR_INTERVAL_MS=259200000
RCAPE_MONITOR_MAX_PER_CYCLE=3

# Watchlist sweeper (optional) — auto-shelves cases getting media attention. Set
# RCAPE_WATCHLIST_URI to the at:// URI of a curated, consent-based Bluesky list
# (app.bsky.graph.list) of legal journalists / court-watchers you maintain; the
# bot reads its feed and provisions a docket once ≥ THRESHOLD distinct list members
# share a CourtListener /docket/ link. Only direct docket links count (no caption
# inference), reads cost no CL quota, and provisioning is budget-gated so a trending
# case never starves a by-request user. Absent ⇒ the sweeper is off (by-request only).
#
# Getting the at:// URI: create a list in the Bluesky app; its web URL is
# bsky.app/profile/<handle>/lists/<rkey>. The at:// form is
#   at://<your-did>/app.bsky.graph.list/<rkey>
# where <rkey> is that trailing segment and <your-did> is your account DID (resolve
# the handle with e.g. `goat resolve <handle>` or the com.atproto.identity.resolveHandle XRPC).
RCAPE_WATCHLIST_URI=
# Distinct members that must share a docket before it trips (default 1 — raise to
# 2+ once the list grows, to require corroboration).
RCAPE_WATCHLIST_THRESHOLD=1
# How long between list-feed reads (ms; default 30 min = 1800000).
RCAPE_WATCHLIST_INTERVAL_MS=1800000
# Max cases auto-shelved per sweep (the rest roll to later sweeps).
RCAPE_WATCHLIST_MAX_PER_CYCLE=3
# Min token budget (CL calls) required before an auto-shelve — this case plus a
# live request's reserve (default 24). Discretionary work must not starve requests.
# The reserve is PER TOKEN; with CourtListener's single-token limit (a 2nd token is
# ToS-forbidden) that's the whole budget, so the guarantee is pool-wide in practice.
RCAPE_WATCHLIST_PROVISION_FLOOR=24

# Pre-shelve harvest (optional) — grows the archive from a PRIVATE set of legal-
# journalist accounts you curate. The bot reads their public feeds, queues the
# CourtListener dockets they link, and shelves them ONLY near the daily reset with
# spare quota (never starving by-request users). The source accounts are NEVER
# published or @-mentioned — this is quiet pre-provisioning of public court records,
# not a "watched" list (distinct from the consent-gated watchlist sweeper). Set to a
# comma-separated list of handles or DIDs; absent/empty ⇒ off.
RCAPE_HARVEST_ACCOUNTS=
# Harvest cadence (ms; default 3h), the window before UTC midnight in which the
# pre-shelve queue drains (ms; default 3h), the CL-call reserve a token must keep
# before a pre-shelve provision (default 60 — high, so discretionary work only uses
# comfortable surplus), and the max pre-shelve cases per drain cycle (default 3).
RCAPE_HARVEST_INTERVAL_MS=10800000
RCAPE_HARVEST_DRAIN_WINDOW_MS=10800000
RCAPE_HARVEST_FLOOR=60
RCAPE_HARVEST_MAX_PER_DRAIN=3

# Notify-thread carve-out (optional) — comma-separated DIDs (Chris Geidner) who get
# a one-time courtesy reply UNDER their triggering post when a docket harvested from
# it is fully shelved, plus a guarantee the bot never posts into their threads again
# (any other engagement is answered as a NEW top-level thread). DIDs only (must match
# the thread-root author at runtime); absent ⇒ no source replies, no re-routing.
RCAPE_NOTIFY_THREAD_ACCOUNTS=

# Announce-on-provision — when the bot mints a NEW case account it posts a standalone
# skeet from @ape.rcape.org linking the new case (by-request and pre-shelve alike).
# On by default; set to 0/false to disable.
RCAPE_ANNOUNCE_PROVISIONS=1

# Gemini (optional) — arms v1b prose case-inference: when a mention and its
# thread carry no docket link, Gemini proposes a {caption, court} hint and ONE
# CourtListener search verifies it (provision only on exactly-one match).
# Absent, the bot just asks for a docket link. Free-tier key:
# https://aistudio.google.com/apikey
RCAPE_GEMINI_API_KEY=
RCAPE_GEMINI_MODEL=gemini-2.5-flash-lite

# Public directory (optional) — regenerates a gist table of every shelved docket
# and a combined pinned post on @ape.rcape.org after each provision/monitor add.
# RCAPE_GIST_TOKEN and RCAPE_DIRECTORY_GIST_ID must BOTH be set to push the gist;
# the native app.bsky.graph.list runs without them (bot self-auth only). The token
# is a PropterMalone gist-scoped PAT; the id is the shelf gist created once under
# PropterMalone (gh gist create) and must be a 20–40 char hex id.
RCAPE_GIST_TOKEN=
RCAPE_DIRECTORY_GIST_ID=

# Lexicon publisher (optional) — the atproto account whose repo hosts the
# published com.rcape.* lexicon schemas. Used by the lexicon-publishing CLI only,
# not the bot's runtime. Leave blank unless (re)publishing the lexicons.
RCAPE_LEXICON_PUBLISHER_DID=
RCAPE_LEXICON_PUBLISHER_PASSWORD=

# A single live case account for the operator CLIs (publish / fire / takedown).
# Bot-provisioned cases store their own credentials in data/ledger.json.
RCAPE_CASE_DID=
RCAPE_CASE_PASSWORD=

# Cloudflare — creates _atproto.<handle>.rcape.org TXT records so PDS-issued
# handles resolve on the network (no wildcard; one TXT per handle).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
