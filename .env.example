# CourtListener — free token at https://www.courtlistener.com/profile/
COURTLISTENER_API_TOKEN=

# Default docket for the operator build path (Abrego Garcia v. Noem, D. Md.)
RCAPE_DOCKET_ID=69777799
# How many leading entries to hash documents for (build path)
RCAPE_HASH_FIRST_N=15
# How many recent entries stage:posts proposes (stage path)
RCAPE_BACKFILL_N=10

# Self-hosted PDS on Malone. Admin password also lives in pds/pds.env; copy it
# here so the provisioner can mint case accounts.
PDS_HOSTNAME=pds.rcape.org
PDS_ADMIN_PASSWORD=

# Handle domain the PDS issues handles under (matches PDS_SERVICE_HANDLE_DOMAINS)
RCAPE_HANDLE_DOMAIN=rcape.org
# The main R.C. Ape "Librarian" bot identity — the account that receives
# @-mentions. Mint it, then fill its DID + password here to run `npm run bot`.
RCAPE_BOT_HANDLE=ape.rcape.org
RCAPE_BOT_DID=
RCAPE_BOT_PASSWORD=
# Owner whose follows ∪ followers form the bot's allowlist (handle or DID)
RCAPE_OWNER_HANDLE=proptermalone.bsky.social
# Allowlist cache TTL (ms). Soft cache only — drain re-checks membership before
# provisioning, so this just bounds how stale an enqueue-time decision can be.
RCAPE_ALLOWLIST_TTL_MS=60000
# Bot notification poll interval (ms)
RCAPE_POLL_INTERVAL_MS=60000

# A single live case account for the operator CLIs (publish / fire / takedown).
# Bot-provisioned cases store their own credentials in data/ledger.json.
RCAPE_CASE_DID=
RCAPE_CASE_PASSWORD=

# Cloudflare — creates _atproto.<handle>.rcape.org TXT records so PDS-issued
# handles resolve on the network (no wildcard; one TXT per handle).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
